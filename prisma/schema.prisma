// Recall — Prisma schema
// Postgres on Neon (free tier). Run `npx prisma db push` after configuring DATABASE_URL.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum ContentType {
  TEXT
  LINK
  PDF
  MARKDOWN
  CODE
  IMAGE
}

enum ReviewMode {
  FLIP
  TYPE
  RECALL_BUTTONS
  AI_QUIZ
}

enum NotifyChannel {
  EMAIL
  PUSH
}

// ---------- Models ----------

model User {
  id            String   @id // Clerk user id
  email         String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  timezone      String   @default("UTC")
  emailEnabled  Boolean  @default(true)
  pushEnabled   Boolean  @default(true)
  /// Encrypted at rest; AES-256-GCM with ENCRYPTION_KEY. Format: iv:tag:ciphertext (hex).
  anthropicKey  String?
  /// Optional Claude model override. Defaults to env ANTHROPIC_DEFAULT_MODEL.
  anthropicModel String?
  /// Personal best — longest consecutive day streak of completing reviews.
  longestStreak Int      @default(0)

  pushSubs   PushSubscription[]
  items      Item[]
  reviews    Review[]
  tags       Tag[]
  notifyLogs NotifyLog[]
}

model Item {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  contentType   ContentType
  rawContent    String      @db.Text // pasted text / URL / markdown / code
  /// Extracted plain text for PDFs, link OpenGraph previews, etc. Powers search.
  extractedText String?     @db.Text
  sourceUrl     String?
  learnedAt     DateTime
  reviewMode    ReviewMode  @default(RECALL_BUTTONS)
  aiEnabled     Boolean     @default(false)
  /// Cached AI-generated quiz Q&A. Shape: [{ q: string, a: string }, ...]
  aiQuestions   Json?
  /// Cached AI summary (1-2 lines).
  aiSummary     String?     @db.Text
  /// Cached AI key concepts (3-5 strings).
  aiConcepts    Json?
  /// User's own elaboration notes ("how does this connect to what I know").
  notes         String?     @db.Text

  // FSRS state (mirrors ts-fsrs Card)
  due           DateTime  @default(now())
  stability     Float     @default(0)
  difficulty    Float     @default(0)
  elapsedDays   Int       @default(0)
  scheduledDays Int       @default(0)
  reps          Int       @default(0)
  lapses        Int       @default(0)
  state         Int       @default(0) // 0=New 1=Learning 2=Review 3=Relearning
  lastReview    DateTime?

  // Organization
  tags       Tag[]    @relation("ItemTags")
  archived   Boolean  @default(false)
  related    Item[]   @relation("RelatedItems")
  relatedBy  Item[]   @relation("RelatedItems")
  reviews    Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, due])
  @@index([userId, archived])
  @@index([userId, createdAt])
}

model Review {
  id         String   @id @default(cuid())
  itemId     String
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating     Int // 1=Again 2=Hard 3=Good 4=Easy
  reviewedAt DateTime @default(now())
  /// Time taken to answer, in milliseconds.
  elapsedMs  Int?
  /// What the user typed/picked, if any. For AI quiz / TYPE mode answers.
  answer     String?  @db.Text
  /// AI grader feedback, if AI_QUIZ.
  aiFeedback String?  @db.Text

  @@index([userId, reviewedAt])
  @@index([itemId, reviewedAt])
}

model Tag {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  color  String?
  items  Item[]  @relation("ItemTags")

  @@unique([userId, name])
  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Tracks daily digest sends so we never spam a user twice on the same day.
model NotifyLog {
  id      String        @id @default(cuid())
  userId  String
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel NotifyChannel
  /// YYYY-MM-DD in the user's timezone.
  dayKey  String
  sentAt  DateTime      @default(now())
  /// Snapshot of how many items were due when we notified.
  dueCount Int          @default(0)

  @@unique([userId, channel, dayKey])
  @@index([userId, sentAt])
}
